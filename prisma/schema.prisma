generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SessionStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum SummaryDepth {
  BRIEF
  STANDARD
  DETAILED
}

enum TutorRole {
  USER
  TUTOR
}

model User {
  id                    String                 @id
  email                 String?                @unique
  name                  String?
  /// BCP-47 language tag (e.g. "en", "es", "fr"). Set during the language
  /// selection screen shown before the baseline assessment (F-011). Drives
  /// assessment translation, UI locale, and default TTS voice.
  preferredLanguage     String                 @default("en")
  /// IANA timezone name (e.g. "America/Los_Angeles"), captured client-side
  /// via TimezoneSync.tsx. Nullable because it isn't known until the user's
  /// first authenticated page load with JS running. Used so the reading
  /// streak and progress-chart dates reflect the reader's actual calendar
  /// day instead of the server's UTC day — without this, a session at, say,
  /// 4pm Pacific can land on a different "day" than one at 3:59pm the same
  /// afternoon, purely because that moment crosses midnight UTC.
  timezone              String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  readingSessions       ReadingSession[]
  quizAttempts          QuizAttempt[]
  baselineAssessment    BaselineAssessment?
  vocabularyWords       VocabularyWord[]
  highlightInteractions HighlightInteraction[]
  vocabularyReviews     VocabularyReview[]
  visualGameAttempts    VisualGameAttempt[]
  listeningGames        ListeningGame[]
  listeningAttempts     ListeningAttempt[]
}

/// Permanent baseline scores captured during onboarding (F-017).
/// One record per user; all future progress is measured against this baseline.
/// Never overwritten — there is intentionally no update path.
model BaselineAssessment {
  id                 String   @id @default(cuid())
  userId             String   @unique
  readingSpeedWPM    Int
  comprehensionScore Float
  vocabularyScore    Float
  inferenceScore     Float
  overallScore       Float
  takenAt            DateTime
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReadingSession {
  id                String        @id @default(cuid())
  userId            String
  title             String
  sourceText        String        @db.Text
  wordCount         Int?
  sourceUrl         String?
  status            SessionStatus @default(DRAFT)
  /// Index of the next unread chunk (F-002). Chunks are derived from
  /// sourceText at render time, not persisted — this is the only progress
  /// marker we need to resume a session.
  currentChunkIndex Int           @default(0)
  /// Total active reading time across all chunks, in seconds (F-005). Accrued
  /// incrementally by submitChunkSummary from client-reported per-chunk
  /// durations — clamped server-side, not a precise instrument.
  elapsedSeconds    Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  completedAt       DateTime?

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary               Summary?
  quizzes               Quiz[]
  chunkSummaries        ChunkSummary[]
  vocabularyWords       VocabularyWord[]
  highlightInteractions HighlightInteraction[]
  tutorMessages         TutorMessage[]
  visualGames           VisualGame[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status])
}

/// A word a reader looked up while reading (F-004). One row per distinct
/// word per user — looking the same word up again from another session just
/// reuses this row instead of re-querying the dictionary API.
model VocabularyWord {
  id              String   @id @default(cuid())
  userId          String
  word            String
  partOfSpeech    String?
  phonetic        String?
  definition      String   @db.Text
  etymology       String?  @db.Text
  synonyms        String[]
  sourceSessionId String?
  createdAt       DateTime @default(now())

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceSession ReadingSession? @relation(fields: [sourceSessionId], references: [id], onDelete: SetNull)
  review        VocabularyReview?

  @@unique([userId, word])
  @@index([userId, createdAt(sort: Desc)])
}

/// Spaced-repetition scheduling state for one vocabulary word (F-014).
/// Created lazily the first time a word is reviewed in the memory game —
/// words with no row yet are treated as due immediately. On a correct answer
/// the interval climbs a Leitner-style ladder; on a miss it resets to zero so
/// the word comes back in the same review session.
model VocabularyReview {
  id               String    @id @default(cuid())
  userId           String
  vocabularyWordId String    @unique
  nextReviewAt     DateTime  @default(now())
  intervalDays     Int       @default(0)
  correctStreak    Int       @default(0)
  lastReviewedAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabularyWord VocabularyWord @relation(fields: [vocabularyWordId], references: [id], onDelete: Cascade)

  @@index([userId, nextReviewAt])
}

/// A user's micro-summary or chosen keywords for one chunk of a reading
/// session (F-003). Exactly one of summaryText/keywords is set, enforced in
/// the submitChunkSummary server action rather than the DB. Writing this row
/// is what's allowed to advance ReadingSession.currentChunkIndex — there is
/// intentionally no other path to unlock the next chunk.
/// A user's micro-summary or chosen keywords for one chunk of a reading
/// session (F-003). Exactly one of summaryText/keywords is set, enforced in
/// the submitChunkSummary server action rather than the DB. Writing this row
/// is what's allowed to advance ReadingSession.currentChunkIndex — there is
/// intentionally no other path to unlock the next chunk.
/// aiScore and aiFeedback are populated asynchronously by Claude after the
/// row is written; they are nullable so the row can be created and the user
/// can advance before scoring completes.
model ChunkSummary {
  id          String   @id @default(cuid())
  sessionId   String
  chunkIndex  Int
  summaryText String?  @db.Text
  keywords    String[]
  /// Claude score 0-100. Null until scored; keywords-mode rows are also scored
  /// based on relevance so this field is populated for both modes.
  aiScore     Int?
  /// 1-2 sentence encouraging feedback from Claude. Null until scored.
  aiFeedback  String?  @db.Text
  createdAt   DateTime @default(now())

  session ReadingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, chunkIndex])
}

model Summary {
  id               String       @id @default(cuid())
  sessionId        String       @unique
  depth            SummaryDepth
  content          String       @db.Text
  model            String
  promptTokens     Int?
  completionTokens Int?
  createdAt        DateTime     @default(now())

  session ReadingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Quiz {
  id            String        @id @default(cuid())
  sessionId     String
  questionCount Int
  model         String
  createdAt     DateTime      @default(now())

  session   ReadingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  QuizAttempt[]

  @@index([sessionId])
}

model Question {
  id           String  @id @default(cuid())
  quizId       String
  orderIndex   Int
  prompt       String  @db.Text
  options      Json
  correctIndex Int
  explanation  String? @db.Text

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, orderIndex])
}

model QuizAttempt {
  id           String   @id @default(cuid())
  quizId       String
  userId       String
  answers      Json
  score        Float
  correctCount Int
  totalCount   Int
  createdAt    DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([quizId, userId])
}

/// Every time the Highlight Tutor is invoked — the user selected text and
/// clicked "Ask Tutor" — one row is written here (fire-and-forget, non-blocking).
/// Used for admin analytics (F-019) and future personalization.
model HighlightInteraction {
  id                String   @id @default(cuid())
  userId            String
  sessionId         String
  /// The exact text the reader highlighted (capped at 2 000 chars server-side).
  selectedText      String   @db.Text
  /// The surrounding paragraph for context (capped at 4 000 chars server-side).
  surroundingContext String?  @db.Text
  createdAt         DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  session ReadingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([sessionId])
}

/// One turn in a Socratic tutor session (Phase 3). Each question Claude asks
/// and each answer the user gives is stored as a separate row. The full
/// conversation history is reconstructed client-side from component state and
/// passed to the API; this table is the persistent log for analytics (F-019)
/// and future personalization.
model TutorMessage {
  id        String    @id @default(cuid())
  sessionId String
  role      TutorRole
  content   String    @db.Text
  createdAt DateTime  @default(now())

  session ReadingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

/// F-013 — which visual comprehension exercise a game contains.
enum VisualGameType {
  MATCHING
  SEQUENCING
}

/// One generated visual learning game (F-013), tied to the reading session
/// whose sourceText it was generated from. Mirrors the Quiz pattern.
model VisualGame {
  id        String         @id @default(cuid())
  sessionId String
  gameType  VisualGameType
  model     String
  createdAt DateTime       @default(now())

  session  ReadingSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  items    VisualGameItem[]
  attempts VisualGameAttempt[]

  @@index([sessionId, gameType])
}

/// One exercise round inside a visual game. `itemData` holds the
/// client-safe display payload (terms + shuffled descriptions for MATCHING,
/// shuffled steps for SEQUENCING); `correctAnswer` holds the solution as
/// `{ selections: number[] }` and must NEVER be sent to the client — games
/// are graded server-side in the submitVisualGameAttempt action.
model VisualGameItem {
  id            String         @id @default(cuid())
  visualGameId  String
  orderIndex    Int
  type          VisualGameType
  prompt        String         @db.Text
  itemData      Json
  correctAnswer Json

  game VisualGame @relation(fields: [visualGameId], references: [id], onDelete: Cascade)

  @@index([visualGameId, orderIndex])
}

/// One graded play-through of a visual game (F-013).
model VisualGameAttempt {
  id           String   @id @default(cuid())
  visualGameId String
  userId       String
  answers      Json
  score        Float
  createdAt    DateTime @default(now())

  game VisualGame @relation(fields: [visualGameId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([visualGameId, userId])
}

/// One listening comprehension game built from user-pasted song lyrics
/// (F-015). The lyrics are supplied by the user — there is deliberately no
/// lyric search or licensing integration.
model ListeningGame {
  id        String   @id @default(cuid())
  userId    String
  title     String
  model     String
  createdAt DateTime @default(now())

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  segments ListeningSegment[]
  attempts ListeningAttempt[]

  @@index([userId, createdAt(sort: Desc)])
}

/// One Claude-segmented chunk of the lyrics. `questions` holds
/// `{ blankAnswers: string[], question: { prompt, options, correctIndex } }`
/// — the answer key. Like VisualGameItem.correctAnswer, it is server-only:
/// the generate route strips it before responding, and grading happens in
/// the submitListeningAttempt action.
model ListeningSegment {
  id                    String @id @default(cuid())
  listeningGameId       String
  orderIndex            Int
  lyricText             String @db.Text
  vocabularyAnnotations Json
  blankedText           String @db.Text
  questions             Json

  game ListeningGame @relation(fields: [listeningGameId], references: [id], onDelete: Cascade)

  @@index([listeningGameId, orderIndex])
}

/// One graded play-through of a listening game (F-015).
model ListeningAttempt {
  id              String   @id @default(cuid())
  listeningGameId String
  userId          String
  answers         Json
  score           Float
  createdAt       DateTime @default(now())

  game ListeningGame @relation(fields: [listeningGameId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([listeningGameId, userId])
}
