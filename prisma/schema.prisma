generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SessionStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum SummaryDepth {
  BRIEF
  STANDARD
  DETAILED
}

enum TutorRole {
  USER
  TUTOR
}

model User {
  id                    String                 @id
  email                 String?                @unique
  name                  String?
  /// BCP-47 language tag (e.g. "en", "es", "fr"). Set during the language
  /// selection screen shown before the baseline assessment (F-011). Drives
  /// assessment translation, UI locale, and default TTS voice.
  preferredLanguage     String                 @default("en")
  /// IANA timezone name (e.g. "America/Los_Angeles"), captured client-side
  /// via TimezoneSync.tsx. Nullable because it isn't known until the user's
  /// first authenticated page load with JS running. Used so the reading
  /// streak and progress-chart dates reflect the reader's actual calendar
  /// day instead of the server's UTC day — without this, a session at, say,
  /// 4pm Pacific can land on a different "day" than one at 3:59pm the same
  /// afternoon, purely because that moment crosses midnight UTC.
  timezone              String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  readingSessions       ReadingSession[]
  quizAttempts          QuizAttempt[]
  baselineAssessment    BaselineAssessment?
  vocabularyWords       VocabularyWord[]
  highlightInteractions HighlightInteraction[]
  communityPosts        CommunityPost[]
  communityComments     CommunityComment[]
}

/// Permanent baseline scores captured during onboarding (F-017).
/// One record per user; all future progress is measured against this baseline.
/// Never overwritten — there is intentionally no update path.
model BaselineAssessment {
  id                 String   @id @default(cuid())
  userId             String   @unique
  readingSpeedWPM    Int
  comprehensionScore Float
  vocabularyScore    Float
  inferenceScore     Float
  overallScore       Float
  takenAt            DateTime
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReadingSession {
  id                String        @id @default(cuid())
  userId            String
  title             String
  sourceText        String        @db.Text
  wordCount         Int?
  sourceUrl         String?
  status            SessionStatus @default(DRAFT)
  /// Index of the next unread chunk (F-002). Chunks are derived from
  /// sourceText at render time, not persisted — this is the only progress
  /// marker we need to resume a session.
  currentChunkIndex Int           @default(0)
  /// Total active reading time across all chunks, in seconds (F-005). Accrued
  /// incrementally by submitChunkSummary from client-reported per-chunk
  /// durations — clamped server-side, not a precise instrument.
  elapsedSeconds    Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  completedAt       DateTime?

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary               Summary?
  quizzes               Quiz[]
  chunkSummaries        ChunkSummary[]
  vocabularyWords       VocabularyWord[]
  highlightInteractions HighlightInteraction[]
  tutorMessages         TutorMessage[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status])
}

/// A word a reader looked up while reading (F-004). One row per distinct
/// word per user — looking the same word up again from another session just
/// reuses this row instead of re-querying the dictionary API.
model VocabularyWord {
  id              String   @id @default(cuid())
  userId          String
  word            String
  partOfSpeech    String?
  phonetic        String?
  definition      String   @db.Text
  etymology       String?  @db.Text
  synonyms        String[]
  sourceSessionId String?
  createdAt       DateTime @default(now())

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceSession ReadingSession? @relation(fields: [sourceSessionId], references: [id], onDelete: SetNull)

  @@unique([userId, word])
  @@index([userId, createdAt(sort: Desc)])
}

/// A user's micro-summary or chosen keywords for one chunk of a reading
/// session (F-003). Exactly one of summaryText/keywords is set, enforced in
/// the submitChunkSummary server action rather than the DB. Writing this row
/// is what's allowed to advance ReadingSession.currentChunkIndex — there is
/// intentionally no other path to unlock the next chunk.
/// A user's micro-summary or chosen keywords for one chunk of a reading
/// session (F-003). Exactly one of summaryText/keywords is set, enforced in
/// the submitChunkSummary server action rather than the DB. Writing this row
/// is what's allowed to advance ReadingSession.currentChunkIndex — there is
/// intentionally no other path to unlock the next chunk.
/// aiScore and aiFeedback are populated asynchronously by Claude after the
/// row is written; they are nullable so the row can be created and the user
/// can advance before scoring completes.
model ChunkSummary {
  id          String   @id @default(cuid())
  sessionId   String
  chunkIndex  Int
  summaryText String?  @db.Text
  keywords    String[]
  /// Claude score 0-100. Null until scored; keywords-mode rows are also scored
  /// based on relevance so this field is populated for both modes.
  aiScore     Int?
  /// 1-2 sentence encouraging feedback from Claude. Null until scored.
  aiFeedback  String?  @db.Text
  createdAt   DateTime @default(now())

  session ReadingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, chunkIndex])
}

model Summary {
  id               String       @id @default(cuid())
  sessionId        String       @unique
  depth            SummaryDepth
  content          String       @db.Text
  model            String
  promptTokens     Int?
  completionTokens Int?
  createdAt        DateTime     @default(now())

  session ReadingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Quiz {
  id            String        @id @default(cuid())
  sessionId     String
  questionCount Int
  model         String
  createdAt     DateTime      @default(now())

  session   ReadingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  QuizAttempt[]

  @@index([sessionId])
}

model Question {
  id           String  @id @default(cuid())
  quizId       String
  orderIndex   Int
  prompt       String  @db.Text
  options      Json
  correctIndex Int
  explanation  String? @db.Text

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, orderIndex])
}

model QuizAttempt {
  id           String   @id @default(cuid())
  quizId       String
  userId       String
  answers      Json
  score        Float
  correctCount Int
  totalCount   Int
  createdAt    DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([quizId, userId])
}

/// Every time the Highlight Tutor is invoked — the user selected text and
/// clicked "Ask Tutor" — one row is written here (fire-and-forget, non-blocking).
/// Used for admin analytics (F-019) and future personalization.
model HighlightInteraction {
  id                String   @id @default(cuid())
  userId            String
  sessionId         String
  /// The exact text the reader highlighted (capped at 2 000 chars server-side).
  selectedText      String   @db.Text
  /// The surrounding paragraph for context (capped at 4 000 chars server-side).
  surroundingContext String?  @db.Text
  createdAt         DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  session ReadingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([sessionId])
}

/// One turn in a Socratic tutor session (Phase 3). Each question Claude asks
/// and each answer the user gives is stored as a separate row. The full
/// conversation history is reconstructed client-side from component state and
/// passed to the API; this table is the persistent log for analytics (F-019)
/// and future personalization.
model TutorMessage {
  id        String    @id @default(cuid())
  sessionId String
  role      TutorRole
  content   String    @db.Text
  createdAt DateTime  @default(now())

  session ReadingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

/// A community post (F-016 MVP) — plain text, authored by a signed-in user.
model CommunityPost {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments CommunityComment[]

  @@index([createdAt(sort: Desc)])
  @@index([userId])
}

/// A threaded comment on a community post (F-016 MVP). Nesting is via
/// parentId (null = top-level). Deleting a comment cascades to its replies
/// — an explicit MVP tradeoff, documented in SCHEMA.md; a soft-delete
/// placeholder can replace it if threads need to survive mid-node deletes.
model CommunityComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  parentId  String?
  body      String   @db.Text
  createdAt DateTime @default(now())

  post    CommunityPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  CommunityComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies CommunityComment[] @relation("CommentReplies")

  @@index([postId, createdAt])
  @@index([userId])
}
